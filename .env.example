# Riprap environment configuration.
#
# Copy this file to `.env` and fill in the values that match the
# inference backend you want to talk to. The default profile runs
# only the app container, so both the LLM (vLLM serving Granite 4.1)
# and the ML specialist service must be reachable at HTTP endpoints.
#
# Three common configurations:
#
#   1. Easiest — talk to the live demo's backends. Adam runs a public
#      MI300X droplet for the hackathon; if it's still up at demo time,
#      both endpoints are reachable from anywhere.
#
#   2. Self-hosted — bring up your own MI300X droplet via
#      docs/DROPLET-RUNBOOK.md, then point both URLs at it.
#
#   3. Full local — use `docker compose --profile with-models up` to
#      run the riprap-models service yourself (requires a GPU on your
#      box) and point a separate vLLM container at Granite 4.1.
#
#   4. NGO / CPU-only — use `docker compose --profile local-llm up`,
#      which bundles an Ollama service with 4 parallel slots. Set
#      RIPRAP_LLM_PRIMARY=ollama and OLLAMA_BASE_URL=http://ollama:11434
#      below. For zero-LLM operation (deterministic templated prose),
#      set RIPRAP_RECONCILER_TIER=templated.

# ---- Reconciler tier --------------------------------------------------
# `llm` (default)      — Granite 4.1 produces the prose. Granite runs
#                        twice per query: once as planner (classify the
#                        intent + targets) and once as reconciler
#                        (write the cited briefing prose).
# `no_llm`             — Disables BOTH Granite calls. The planner is
#                        replaced by a regex heuristic; the reconciler
#                        is replaced by deterministic templated prose
#                        synthesized from each pebble's narration
#                        template. Everything else runs unchanged —
#                        Prithvi-EO, TerraMind, TTM, GLiNER, RAG
#                        embeddings (the specialist ML pebbles)
#                        still populate state and the dashboards.
#                        Right shape for civic-tech audit, Pi-class
#                        hardware, and "give me the standard info"
#                        queries without paying for LLM inference.
#                        (Legacy value `templated` is accepted as an
#                        alias for `no_llm`.)
RIPRAP_RECONCILER_TIER=llm

# ---- Reconciler model -------------------------------------------------
# Which Granite model the `llm` reconciler tier uses. Two profiles:
#   granite4.1:8b      — production default, ~30s reconcile, best quality
#   granite4.1:8b-q3_K_M  — 4 GB quant, fits in 16 GB box w/ NUM_PARALLEL=4
#   granite4.1:3b      — small / Pi profile, ~10s reconcile on CPU,
#                        fits comfortably on Pi 5 8 GB. The 3B is
#                        markedly less polished prose; rely on the
#                        compliance predicates to hold the bar.
# Override RIPRAP_OLLAMA_8B_TAG / RIPRAP_OLLAMA_3B_TAG to point logical
# aliases at specific quantizations.
RIPRAP_RECONCILER_MODEL=granite4.1:8b

# ---- Granite 4.1 reconciler (vLLM, OpenAI-compatible) -----------------
# Set to "ollama" instead of "vllm" if you have a local Ollama (e.g.
# the bundled `local-llm` compose profile). OLLAMA_BASE_URL points
# the LiteLLM router at it — defaults to localhost:11434.
RIPRAP_LLM_PRIMARY=vllm
RIPRAP_LLM_BASE_URL=http://your-vllm-host:8000/v1
RIPRAP_LLM_API_KEY=your-token-here
# OLLAMA_BASE_URL=http://ollama:11434           # for `local-llm` profile

# ---- LLM concurrency (Ollama path) ------------------------------------
# Override the bundled Ollama service's parallel-slot count. Each slot
# costs ~500 MB of KV cache at 4K context; weights are shared. 4 is
# comfortable on a 16 GB box for granite4.1:3b.
OLLAMA_NUM_PARALLEL=4

# ---- ML specialist service (Prithvi, TerraMind, GLiNER, etc.) ---------
RIPRAP_ML_BASE_URL=http://your-ml-host:7860
RIPRAP_ML_API_KEY=your-token-here

# ---- Backend pill labels (cosmetic, shown top-right of the UI) --------
RIPRAP_HARDWARE_LABEL=AMD MI300X
RIPRAP_ENGINE_LABEL=Granite 4.1 / vLLM
