# editorconfig.org — keeps editor defaults consistent for contributors
# regardless of OS / editor / IDE preference.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,ts,svelte,json,jsonc,css,html,scss,yaml,yml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
# Markdown is whitespace-sensitive for trailing double-spaces (line
# break markers). Don't trim those.
trim_trailing_whitespace = false
